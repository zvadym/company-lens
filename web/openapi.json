        "title": "AgentErrorSeverity",
        "type": "string"
      },
      "AgentRunStatus": {
        "enum": [
          "pending",
          "running",
          "completed",
          "partial",
          "abstained",
          "failed"
        ],
        "title": "AgentRunStatus",
        "type": "string"
      },
