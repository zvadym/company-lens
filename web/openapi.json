      "AgentError": {
        "properties": {
          "attempt": {
            "default": 1,
            "minimum": 1.0,
            "title": "Attempt",
            "type": "integer"
          },
          "category": {
            "$ref": "#/components/schemas/AgentErrorCategory"
          },
          "code": {
            "pattern": "^[a-z][a-z0-9_]*$",
            "title": "Code",
            "type": "string"
          },
          "message": {
            "minLength": 1,
            "title": "Message",
            "type": "string"
          },
          "node": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Node"
          },
          "severity": {
            "$ref": "#/components/schemas/AgentErrorSeverity"
          }
        },
        "required": [
          "category",
          "severity",
          "code",
          "message"
        ],
        "title": "AgentError",
        "type": "object"
      },
      "AgentErrorCategory": {
        "enum": [
          "validation",
          "provider_timeout",
          "provider_rate_limit",
          "provider_connection",
          "provider_auth",
          "provider_service",
          "provider_refusal",
          "provider_response",
          "tool",
          "budget",
          "internal"
        ],
        "title": "AgentErrorCategory",
        "type": "string"
      },
      "AgentErrorSeverity": {
        "enum": [
          "recoverable",
          "terminal"
